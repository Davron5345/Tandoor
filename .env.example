PORT=3001
NODE_ENV=production

# Разрешённые origins для CORS (через запятую). Для отдельного фронта на другом домене.
# На Railway с одним сервисом можно не задавать — домен подставится из RAILWAY_PUBLIC_DOMAIN.
# CORS_ORIGIN=https://your-app.example.com

# Постоянная папка для БД и загрузок (обязательно на Railway / Docker / VPS)
# Локально можно не задавать — используется ./data
# Railway: смонтируйте Volume на /data и укажите:
# DATA_DIR=/data

# DATA_DIR=/data
# DISABLE_DEMO_SEED=true

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ENABLED=true

# Push-уведомления для мобильного приложения снабженца (PWA)
# Сгенерировать: node server/scripts/generate-vapid.mjs
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@your-domain.com
