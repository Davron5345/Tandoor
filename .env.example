PORT=3001
NODE_ENV=production

# Постоянная папка для БД и загрузок (обязательно на Railway / Docker / VPS)
# Локально можно не задавать — используется ./data
# Railway: смонтируйте Volume на /data и укажите:
# DATA_DIR=/data

# DATA_DIR=/data
# DISABLE_DEMO_SEED=true

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ENABLED=true
