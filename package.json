{
  "name": "prihod-rashod",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "node server/index.js",
    "setup": "npm install && npm install --prefix client --include=dev",
    "db:backup": "node server/scripts/db-backup.mjs",
    "db:verify": "node server/scripts/db-verify.mjs",
    "db:list-backups": "node server/scripts/db-list-backups.mjs",
    "db:restore": "node server/scripts/db-restore.mjs",
    "vapid:generate": "node server/scripts/generate-vapid.mjs",
    "perms:verify": "node server/scripts/verify-cashier-perms.mjs",
    "cap:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "node scripts/build-android.mjs",
    "icons:generate": "node scripts/generate-app-icons.mjs",
    "test": "node --test server/test/**/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:all": "npm test && npm run test:e2e",
    "lint": "eslint server client/src e2e --max-warnings 0"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/android": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/local-notifications": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.2.0",
    "node-telegram-bot-api": "^0.66.0",
    "sql.js": "^1.12.0",
    "uuid": "^11.0.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.51.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "sharp": "^0.35.2"
  }
}
